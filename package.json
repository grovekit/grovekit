{
  "workspaces": [
    "packages/libs/utils",
    "packages/libs/database",
    "packages/apps/control",
    "packages/apps/scribe"
  ],
  "devDependencies": {
    "@runtyped/type-compiler": "^2.0.0-alpha.3",
    "@types/node": "^26.0.0",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "npm:clean": "rm -rf ./node_modules && rm -rf ./packages/*/*/node_modules",
    "ts:build": "npm run ts:clean && tsc -b ./tsconfig.build.json",
    "ts:watch": "npm run ts:clean && tsc -b ./tsconfig.build.json --watch",
    "ts:clean": "rm -rf packages/*/*/dist && rm -f packages/*/*/tsconfig.tsbuildinfo",
    "postinstall": "npx runtyped-install-transformer"
  }
}
